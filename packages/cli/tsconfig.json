{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@bureauos/core": ["../core/src/index.ts"],
      "@bureauos/memory": ["../memory/src/index.ts"],
      "@bureauos/providers": ["../providers/src/index.ts"],
      "@bureauos/capabilities": ["../capabilities/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "**/*.test.ts"],
  "references": [
    { "path": "../core" },
    { "path": "../memory" },
    { "path": "../providers" },
    { "path": "../capabilities" }
  ]
}
