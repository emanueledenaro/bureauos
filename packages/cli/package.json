{
  "name": "@bureauos/cli",
  "version": "0.0.0",
  "private": true,
  "description": "BureauOS command-line interface: bureau init, status, run, memory, audit",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "bureau": "./dist/bin/bureau.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint pending'"
  },
  "dependencies": {
    "@bureauos/capabilities": "workspace:*",
    "@bureauos/core": "workspace:*",
    "@bureauos/memory": "workspace:*",
    "@bureauos/providers": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  }
}
